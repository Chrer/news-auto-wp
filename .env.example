# WordPress
WORDPRESS_URL=https://enriquevirgen.com
WORDPRESS_USER=qwerty123321
WORDPRESS_APP_PASSWORD=PEGA_AQUI_TU_APPLICATION_PASSWORD
WORDPRESS_STATUS=publish

# Automatización
